---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import { itemListSchema } from '../../utils/schema';
import { buildCanonical } from '../../utils/seo';

const articles = await getCollection('articles', (a) => a.data.category === 'roguelikes');
articles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const listSchema = itemListSchema('Roguelike Guides & Tier Lists', articles.map((a, i) => ({
  name: a.data.title,
  url: `/${a.data.category}/${a.slug}`,
  position: i + 1,
})));
---
<BaseLayout title="Roguelike Guides & Tier Lists" description="Tier lists, build guides, and strategies for the best roguelike and roguelite games." canonical={buildCanonical('/roguelikes')}>
  <div class="container-wide py-10">
    <nav class="text-sm text-ink-500"><a href="/" class="hover:text-brand-700 no-underline">Home</a> / Roguelikes</nav>
    <h1 class="mt-4 text-3xl sm:text-4xl font-extrabold text-ink-900">Roguelike Guides & Tier Lists</h1>
    <p class="mt-2 text-ink-600 max-w-2xl">Tier lists, build guides, and route optimizations for deckbuilders, action roguelikes, and bullet hells.</p>
  </div>
  <AdSlot position="top" />
  <div class="container-wide pb-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {articles.map((a) => (
      <a href={`/roguelikes/${a.slug}`} class="card block p-5 no-underline hover:no-underline">
        <div class="text-xs uppercase tracking-wide font-semibold text-brand-700 mb-2">{a.data.game ?? 'Roguelike'}</div>
        <h2 class="text-lg font-bold text-ink-900 mb-2">{a.data.title}</h2>
        <p class="text-sm text-ink-600 line-clamp-3">{a.data.description}</p>
        <div class="mt-3 text-xs text-ink-500">{a.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
      </a>
    ))}
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(listSchema)} />
</BaseLayout>
