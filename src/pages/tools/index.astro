---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

const tools = await getCollection('tools');
---
<BaseLayout title="Free Idle & Roguelike Game Tools" description="Free interactive calculators, tier list builders, and optimizers for idle, incremental, and roguelike game players. No signup, runs in your browser.">
  <div class="container-wide py-10">
    <nav class="text-sm text-ink-500"><a href="/" class="hover:text-brand-700 no-underline">Home</a> / Tools</nav>
    <h1 class="mt-4 text-3xl sm:text-4xl font-extrabold text-ink-900">Free Game Tools</h1>
    <p class="mt-2 text-ink-600 max-w-2xl">Interactive calculators, tier list generators, and optimizers for idle, incremental, and roguelike game players.</p>
  </div>
  <div class="container-wide pb-4 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {tools.map((t) => <ToolCard name={t.data.name} slug={t.data.slug} description={t.data.description} icon={t.data.icon} />)}
  </div>
  <div class="container-wide pb-12 prose-custom">
    <h2>Why use a game tool?</h2>
    <p>
      Most idle and roguelike games have deep systems: compounding production rates, prestige layers, RNG-heavy drop rates, and complex synergies. A good tool turns those systems into clear numbers so you can make better decisions faster — without spending hours in spreadsheets.
    </p>
    <h2>All our tools</h2>
    <p>
      Every tool on this page is free, runs entirely in your browser, and requires no signup. We add new tools every month based on the games we cover and the questions our readers ask. If you have a tool idea, see our <a href="/contact">contact page</a>.
    </p>
  </div>
</BaseLayout>