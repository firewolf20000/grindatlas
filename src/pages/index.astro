---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import ToolCard from '../components/ToolCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE } from '../utils/seo';

const allArticles = await getCollection('articles');
const recent = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);
const games = await getCollection('games');
const tools = await getCollection('tools');

function slugify(s: string) {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
---
<BaseLayout title={SITE.name} description={SITE.description}>
  <section class="bg-gradient-to-br from-brand-700 via-brand-600 to-brand-500 text-white">
    <div class="container-wide py-16 sm:py-24">
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight max-w-3xl">
        Sharper strategy. Faster progress. Better builds.
      </h1>
      <p class="mt-4 text-lg text-brand-100 max-w-2xl">
        In-depth guides, tier lists, and interactive tools for idle, incremental, and roguelike games. Updated weekly.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/idle-games" class="btn bg-white text-brand-700 hover:bg-brand-50">Browse Idle Games</a>
        <a href="/tools" class="btn bg-brand-800 text-white hover:bg-brand-900">Open Tools</a>
      </div>
    </div>
  </section>

  <AdSlot position="top" />

  <section class="container-wide py-12 prose-custom">
    <h2 class="text-2xl font-bold text-ink-900">What you'll find here</h2>
    <p class="text-ink-700">
      GrindAtlas is a focused guide site for two of the most-played genres on the web: idle and roguelike games. We publish long-form strategy articles, data-driven tier lists, and free browser-based tools that help you make better decisions faster. Every guide is fact-checked against the current version of the game, and every tool is built around the real math that runs in your game — not approximations.
    </p>
    <p class="text-ink-700">
      Whether you are a <em>Cookie Clicker</em> player optimizing your Heavenly Chip build, a <em>Balatro</em> player chasing the gold-stake clear, or a <em>Slay the Spire 2</em> player looking for the strongest card combos, we have a guide for you. We also cover smaller indie titles and the roguelike-adjacent deckbuilder scene. New guides go up every week.
    </p>
  </section>

  <AdSlot position="middle" />

  <section class="container-wide py-12">
    <div class="flex items-end justify-between mb-6">
      <h2 class="text-2xl font-bold">Featured guides</h2>
      <a href="/idle-games" class="text-sm font-semibold text-brand-700">All guides -&gt;</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {recent.map((a) => (
        <a href={`/${a.data.category}/${a.slug}`} class="card block p-5 no-underline hover:no-underline">
          <div class="text-xs uppercase tracking-wide font-semibold text-brand-700 mb-2">{a.data.category.replace('-', ' ')}</div>
          <h3 class="text-lg font-bold text-ink-900 mb-2">{a.data.title}</h3>
          <p class="text-sm text-ink-600 line-clamp-3">{a.data.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="container-wide py-12">
    <div class="flex items-end justify-between mb-6">
      <h2 class="text-2xl font-bold">Interactive tools</h2>
      <a href="/tools" class="text-sm font-semibold text-brand-700">All tools -&gt;</a>
    </div>
    <p class="text-ink-600 mb-6 max-w-2xl">Free browser-based calculators and generators. No signup required, all data stays on your device.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map((t) => (
        <ToolCard name={t.data.name} slug={t.data.slug} description={t.data.description} icon={t.data.icon} />
      ))}
    </div>
  </section>

  <section class="container-wide py-12">
    <h2 class="text-2xl font-bold mb-6">Games we cover</h2>
    <p class="text-ink-600 mb-6 max-w-2xl">We publish in-depth guides and tools for these titles. Click a game to read our coverage.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {games.map((g) => {
        const slug = g.data.slug;
        const article = allArticles.find((a) => a.data.game && slugify(a.data.game) === slug);
        const href = article
          ? `/${article.data.category}/${article.slug}`
          : `/${g.data.category === 'idle' || g.data.category === 'incremental' ? 'idle-games' : g.data.category === 'roguelike' ? 'roguelikes' : 'idle-games'}`;
        return (
          <GameCard
            name={g.data.name}
            slug={slug}
            category={g.data.category === 'idle' || g.data.category === 'incremental' ? 'idle-games' : g.data.category === 'roguelike' ? 'roguelikes' : 'general'}
            shortDescription={g.data.shortDescription}
            href={href}
          />
        );
      })}
    </div>
  </section>
</BaseLayout>