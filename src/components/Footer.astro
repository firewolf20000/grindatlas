---
import { SITE } from '../utils/seo';
const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-ink-200 bg-ink-50">
  <div class="container-wide py-10 grid sm:grid-cols-2 md:grid-cols-4 gap-8 text-sm">
    <div>
      <div class="flex items-center gap-2 font-bold text-ink-900">
        <img src="/favicon.svg" width="24" height="24" alt="" />
        {SITE.name}
      </div>
      <p class="mt-2 text-ink-600">{SITE.description}</p>
    </div>
    <div>
      <h4 class="font-semibold text-ink-900 mb-2">Browse</h4>
      <ul class="space-y-1 text-ink-700">
        <li><a href="/idle-games" class="no-underline hover:underline">Idle Games</a></li>
        <li><a href="/roguelikes" class="no-underline hover:underline">Roguelikes</a></li>
        <li><a href="/tools" class="no-underline hover:underline">Tools</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold text-ink-900 mb-2">Site</h4>
      <ul class="space-y-1 text-ink-700">
        <li><a href="/about" class="no-underline hover:underline">About</a></li>
        <li><a href="/contact" class="no-underline hover:underline">Contact</a></li>
        <li><a href="/privacy-policy" class="no-underline hover:underline">Privacy Policy</a></li>
        <li><a href="/disclaimer" class="no-underline hover:underline">Disclaimer</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold text-ink-900 mb-2">Legal</h4>
      <p class="text-ink-600 text-xs leading-relaxed">
        Game titles, artwork, and trademarks referenced on this site are the property of their respective owners.
        GrindAtlas is a fan-made guide site and is not affiliated with the developers of any game listed.
      </p>
    </div>
  </div>
  <div class="border-t border-ink-200 py-4 text-center text-xs text-ink-500">
    © {year} {SITE.name}. All rights reserved.
  </div>
</footer>
