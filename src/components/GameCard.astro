---
interface Props {
  name: string;
  slug: string;
  category: string;
  shortDescription: string;
  href?: string;
}
const { name, slug, category, shortDescription, href } = Astro.props;
const link = href ?? `/${category}/${slug}`;
---
<a href={link} class="card block p-4 no-underline hover:no-underline">
  <div class="flex items-center gap-2 mb-2">
    <span class="badge">{category.replace('-', ' ')}</span>
  </div>
  <h3 class="text-lg font-bold text-ink-900 mb-1 group-hover:text-brand-700">{name}</h3>
  <p class="text-sm text-ink-600 line-clamp-3">{shortDescription}</p>
</a>
