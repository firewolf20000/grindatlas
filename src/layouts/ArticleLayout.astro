---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { articleSchema, breadcrumbSchema } from '../utils/schema';
import { buildCanonical } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  category: string;
  tags?: string[];
  faq?: { q: string; a: string }[];
  game?: string;
}

const { title, description, pubDate, updatedDate, author, category, tags = [], faq, game } = Astro.props;
const url = buildCanonical(Astro.url.pathname);

const article = articleSchema({
  title,
  description,
  url,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate?.toISOString(),
  authorName: author,
  category,
});

const crumbs = [
  { name: 'Home', url: '/' },
  { name: category.replace('-', ' '), url: `/${category}` },
  { name: title, url: Astro.url.pathname },
];
const crumbsLd = breadcrumbSchema(crumbs);
---
<BaseLayout title={title} description={description} type="article">
  <article class="container-prose py-10">
    <Breadcrumb items={crumbs} />
    <header class="mt-6">
      <div class="flex flex-wrap gap-2 mb-3">
        {game && <a href={`/${category}#${game}`} class="badge">{game}</a>}
        {tags.slice(0, 3).map((t) => <span class="badge">#{t}</span>)}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-ink-900 leading-tight">{title}</h1>
      <p class="mt-3 text-lg text-ink-600">{description}</p>
      <div class="mt-4 text-sm text-ink-500 flex flex-wrap gap-3">
        <span>By {author ?? 'GrindAtlas Editors'}</span>
        <span>闂?/span>
        <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {updatedDate && <>
          <span>闂?/span>
          <span>Updated <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></span>
        </>}
      </div>
    </header>

    <AdSlot position="top" />

    <div class="prose-custom mt-8">
      <slot />
    </div>

    {faq && faq.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold mb-4">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faq.map((x) => (
            <details class="rounded-lg border border-ink-200 p-4">
              <summary class="font-semibold cursor-pointer">{x.q}</summary>
              <p class="mt-2 text-ink-700">{x.a}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <AdSlot position="bottom" />

    <RelatedArticles category={category} currentTitle={title} />
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(article)} />
  <script type="application/ld+json" set:html={JSON.stringify(crumbsLd)} />
  {faq && <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((x) => ({ '@type': 'Question', name: x.q, acceptedAnswer: { '@type': 'Answer', text: x.a } })) })} />
</BaseLayout>