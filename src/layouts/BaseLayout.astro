---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOMeta from '../components/SEOMeta.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { websiteSchema, organizationSchema } from '../utils/schema';
import { SITE, shouldNoindex } from '../utils/seo';
import { VERIFICATION } from '../config/verification';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const { title, description, canonical, image, type = 'website', noindex = false } = Astro.props;
const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const webSchema = websiteSchema();
const orgSchema = organizationSchema();

const isPreviewHost = shouldNoindex(Astro.url.host);
const shouldNoIndexThisPage = noindex || isPreviewHost;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical ?? new URL(Astro.url.pathname, SITE.url).toString()} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googlestagservices.com" />
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname, SITE.url).toString()} />
    <link rel="alternate" hreflang="x-default" href={new URL(Astro.url.pathname, SITE.url).toString()} />
    {shouldNoIndexThisPage && <meta name="robots" content="noindex, nofollow" />}

    <!-- Webmaster verification codes (fill in src/config/verification.ts to activate) -->
    {VERIFICATION.google && <meta name="google-site-verification" content={VERIFICATION.google} />}
    {VERIFICATION.bing   && <meta name="msvalidate.01" content={VERIFICATION.bing} />}
    {VERIFICATION.baidu  && <meta name="baidu-site-verification" content={VERIFICATION.baidu} />}
    {VERIFICATION.yandex && <meta name="yandex-verification" content={VERIFICATION.yandex} />}

    <SEOMeta title={fullTitle} description={description} image={image} type={type} noindex={shouldNoIndexThisPage} />
    <script type="application/ld+json" set:html={JSON.stringify(webSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>